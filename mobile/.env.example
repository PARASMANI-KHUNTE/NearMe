# Environment variables for NearMe mobile
# Copy this file to .env and fill in your values

# ─── Production Backend URLs ───
EXPO_PUBLIC_API_URL=https://nearme-rho.vercel.app/api
EXPO_PUBLIC_SOCKET_URL=https://nearme-rho.vercel.app

# ─── Google OAuth Client IDs (from Google Cloud Console) ───
EXPO_PUBLIC_WEB_GOOGLE_CLIENT_ID=your_web_client_id.apps.googleusercontent.com
EXPO_PUBLIC_ANDROID_GOOGLE_CLIENT_ID=your_android_client_id.apps.googleusercontent.com
EXPO_PUBLIC_IOS_GOOGLE_CLIENT_ID=your_ios_client_id.apps.googleusercontent.com

# ─── Google Maps API Keys (for react-native-maps) ───
GOOGLE_MAPS_ANDROID_API_KEY=your_android_maps_api_key
GOOGLE_MAPS_IOS_API_KEY=your_ios_maps_api_key

# ─── Expo Account ───
EXPO_PUBLIC_EXPO_USERNAME=your_expo_username
EXPO_PUBLIC_EXPO_SLUG=nearme
