{
  "cli": {
    "version": ">= 14.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://nearme-rho.vercel.app/api",
        "EXPO_PUBLIC_SOCKET_URL": "https://nearme-rho.vercel.app"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://nearme-rho.vercel.app/api",
        "EXPO_PUBLIC_SOCKET_URL": "https://nearme-rho.vercel.app"
      }
    },
    "production": {
      "android": {
        "buildType": "apk",
        "image": "latest"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://nearme-rho.vercel.app/api",
        "EXPO_PUBLIC_SOCKET_URL": "https://nearme-rho.vercel.app"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
